{
    "name": "takeone/cropper",
    "description": "Reusable Laravel image cropper using Cropme",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Takeone\\Cropper\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Takeone\\Cropper\\CropperServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    }
}
