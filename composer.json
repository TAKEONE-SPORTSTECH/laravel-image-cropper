{
    "name": "laravel/laravel",
    "type": "project",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://git.innovator.bh/ghassan/laravel-image-cropper"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "takeone/cropper": "dev-main"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}