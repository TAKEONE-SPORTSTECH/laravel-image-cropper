{
    "name": "takeone/cropper",
    "description": "A professional image cropping component for Laravel using Bootstrap and Cropme.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ghassan",
            "email": "ghassan.yousif.83@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Takeone\\Cropper\\": "src/"
        }
    },
    "extra": {
        "laravel": {
